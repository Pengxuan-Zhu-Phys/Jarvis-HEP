{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schemaBlock": {
    "input": {"$ref": "PATH-TO-INPUT-JSON-SCHEMA"},
    "output": {"$ref": "PATH-TO-OUTPUT-JSON-SCHEMA"},
    "Nuisance": {"$ref": "PATH-TO-Nuisance-JSON-SCHEMA"}
  },
  "definitions": {
    "initialization": {
      "type": "array",
      "items": {"type": "string"}
    },
    "execution": {
      "type": "object",
      "properties": {
        "path": {"type": "string"},
        "commands": {
          "type": "array",
          "items": {"type": "string"}
        },
        "input": {"$ref": "#/schemaBlock/input"},
        "output": {"$ref": "#/schemaBlock/output"}
      },
      "required": ["path", "commands", "input", "output"]
    },
    "LogLikelihood": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "expression": {"type": "string"}
        },
        "required": ["name", "expression"],
        "additionalProperties": false
      }
    },
    "variable": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "distribution": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "parameters": {"type": "object"}
          },
          "required": ["type", "parameters"],
          "additionalProperties": true
        }
      },
      "required": ["name", "description", "distribution"],
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["current", "jDE", "lambdajDE", "jde", "lambdajde"]
        },
        "NP": {"type": "integer", "minimum": 5},
        "maxgen": {"type": "integer", "minimum": 1},
        "maxciv": {"type": "integer", "minimum": 1},
        "F": {
          "oneOf": [
            {"type": "number"},
            {
              "type": "array",
              "items": {"type": "number"},
              "minItems": 1
            }
          ]
        },
        "Cr": {"type": "number"},
        "lambda": {"type": "number"},
        "current": {"type": "boolean"},
        "expon": {"type": "boolean"},
        "bndry": {
          "oneOf": [
            {"type": "integer", "enum": [0, 1, 2, 3]},
            {
              "type": "string",
              "enum": [
                "not enforced",
                "none",
                "brick wall",
                "random re-initialization",
                "reflection"
              ]
            }
          ]
        },
        "convthresh": {"type": "number"},
        "convsteps": {"type": "integer", "minimum": 1},
        "removeDuplicates": {"type": "boolean"},
        "discard_unfit_points": {"type": "boolean"},
        "max_acceptable_value": {"type": "number"},
        "seed": {"type": "integer"}
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "properties": {
    "Scan": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "save_dir": {"type": "string"}
      },
      "required": ["name", "save_dir"],
      "additionalProperties": false
    },
    "Sampling": {
      "type": "object",
      "properties": {
        "Method": {"type": "string"},
        "Variables": {
          "type": "array",
          "items": {"$ref": "#/definitions/variable"}
        },
        "run": {"$ref": "#/definitions/run"},
        "Bounds": {"$ref": "#/definitions/run"},
        "MaxWorker": {"type": "integer", "minimum": 1},
        "LogLikelihood": {"$ref": "#/definitions/LogLikelihood"},
        "Nuisance": {"$ref": "#/schemaBlock/Nuisance"}
      },
      "required": ["Variables", "LogLikelihood"],
      "additionalProperties": true
    },
    "EnvReqs": {
      "type": "object",
      "properties": {
        "OS": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "version": {"type": "string"}
            },
            "required": ["name", "version"],
            "additionalProperties": false
          }
        },
        "Python": {
          "type": "object",
          "properties": {
            "version": {"type": "string"},
            "Dependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "required": {"type": "boolean"},
                  "version": {"type": "string"}
                },
                "required": ["name", "required", "version"]
              }
            }
          },
          "required": ["version", "Dependencies"]
        }
      },
      "required": ["OS", "Python"],
      "additionalProperties": true
    },
    "Calculators": {
      "type": "object",
      "properties": {
        "make_paraller": {"type": "integer"},
        "Modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "required_modules": {
                "oneOf": [
                  {"type": "string"},
                  {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                ]
              },
              "clone_shadow": {"type": "boolean"},
              "path": {"type": "string"},
              "source": {"type": "string"},
              "installation": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "required": ["name", "required_modules", "clone_shadow", "installation"],
            "oneOf": [
              {
                "properties": {
                  "modes": {
                    "type": "object",
                    "patternProperties": {
                      "^[a-zA-Z0-9]+$": {
                        "type": "object",
                        "properties": {
                          "initialization": {"$ref": "#/definitions/initialization"},
                          "execution": {"$ref": "#/definitions/execution"}
                        },
                        "required": ["initialization", "execution"]
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": ["modes"]
              },
              {
                "properties": {
                  "initialization": {"$ref": "#/definitions/initialization"},
                  "execution": {"$ref": "#/definitions/execution"}
                },
                "required": ["initialization", "execution"]
              }
            ]
          }
        }
      },
      "required": ["make_paraller", "Modules"]
    },
    "LibDeps": {
      "type": "object",
      "properties": {
        "path": {"type": "string"},
        "make_paraller": {"type": "integer"},
        "Modules": {
          "type": "array",
          "items": {"type": "object"}
        }
      },
      "required": ["path", "make_paraller", "Modules"],
      "additionalProperties": true
    }
  },
  "required": ["Scan", "Sampling", "EnvReqs", "Calculators"],
  "additionalProperties": true
}
