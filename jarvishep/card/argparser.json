{
    "positionals": [
        {
            "name": "file",
            "help": "path of the input file, in yaml format"
        }
    ],
    "options": [
        {
            "short": "-d",
            "long": "--debug",
            "dest": "debug",
            "help": "Run Jarvis-HEP in debug mode, debug mode is testing the program linking",
            "action": "store_true"
        },
        {
            "short": "-v",
            "long": "--version",
            "dest": "version",
            "help": "Print Jarvis-HEP logo, author information and runtime package version",
            "action": "store_true"
        },
        {
            "long": "--refs",
            "dest": "refs",
            "help": "Print full Jarvis-HEP reference information",
            "action": "store_true"
        },
        {
            "long": "--plot",
            "action": "store_true",
            "dest": "plot",
            "help": "Using the plotting mode"
        },
        {
            "long": "--skip-library-installation",
            "action": "store_true",
            "dest": "skiplibrary",
            "help": "Skipping the library installation"
        },
        {
            "long": "--check-modules",
            "action": "store_true",
            "dest": "OPC",
            "help": "For the Calculator test"
        },
        {
            "long": "--skip-draw-flowchart",
            "action": "store_true",
            "dest": "skipFC",
            "help": "Skip JarvisPLOT flowchart.png rendering; flowchart.json is still exported"
        },
        {
            "long": "--convert",
            "action": "store_true",
            "dest": "cvtDB",
            "help": "Convert the sample.hdf5 file into csv format"
        },
        {
            "long": "--monitor",
            "action": "store_true",
            "dest": "monitor",
            "help": "Starts a real-time resource monitoring session for the current Jarvis-HEP job. \n\tNote:\n\t- This monitor updates resource usage statistics in real-time every few seconds.\n\t- Press 'q' in the monitor window to stop monitoring and exit the session."
        },
        {
            "long": "--resume",
            "action": "store_true",
            "dest": "resume",
            "help": "Resume from the latest checkpoint without prompting."
        }
    ]
}
