{
    "positionals": [
        {
            "name": "file",
            "help": "path of the input file, in yaml format"
        }
    ],
    "options": [
        {
            "short": "-d",
            "long": "--debug",
            "dest": "debug",
            "help": "Run Jarvis-HEP in debug mode, debug mode is testing the program linking",
            "action": "store_true"
        },
        {
            "short": "-v",
            "long": "--version",
            "dest": "version",
            "help": "Print Jarvis-HEP logo, author information and runtime package version",
            "action": "store_true"
        },
        {
            "long": "--plot",
            "action": "store_true",
            "dest": "plot",
            "help": "Using the plotting mode"
        },
        {
            "long": "--skip-library-installation",
            "action": "store_true",
            "dest": "skiplibrary",
            "help": "Skipping the library installation"
        },
        {
            "long": "--check-modules",
            "action": "store_true",
            "dest": "OPC",
            "help": "For the Calculator test"
        },
        {
            "long": "--skip-draw-flowchart",
            "action": "store_true",
            "dest": "skipFC",
            "help": "Skipping the flowchart drawing"
        },
        {
            "long": "--convert",
            "action": "store_true",
            "dest": "cvtDB",
            "help": "Convert the sample.hdf5 file into csv format"
        },
        {
            "long": "--monitor",
            "action": "store_true",
            "dest": "monitor",
            "help": "Starts a real-time resource monitoring session for the current Jarvis-HEP job. \n\tNote:\n\t- This monitor updates resource usage statistics in real-time every few seconds.\n\t- Press 'q' in the monitor window to stop monitoring and exit the session."
        },
        {
            "long": "--mkproject",
            "dest": "mkproject",
            "type": "str",
            "help": "Create a standalone Jarvis project folder in the current directory"
        },
        {
            "long": "--packproject",
            "dest": "packproject",
            "type": "str",
            "nargs": "?",
            "const": ".",
            "help": "Package a standalone Jarvis project directory (default: current directory)"
        },
        {
            "long": "--profile",
            "dest": "packprofile",
            "type": "str",
            "default": "repro",
            "choices": ["share", "repro", "full"],
            "help": "Packaging profile for --packproject: share | repro | full"
        },
        {
            "long": "--max-concurrency",
            "dest": "max_concurrency",
            "type": "int",
            "help": "Override Runtime.Subprocess.max_concurrency"
        },
        {
            "long": "--per-task-timeout-sec",
            "dest": "per_task_timeout_sec",
            "type": "float",
            "help": "Override Runtime.Subprocess.per_task_timeout_sec"
        },
        {
            "long": "--progress-interval-sec",
            "dest": "progress_interval_sec",
            "type": "float",
            "help": "Override Runtime.Subprocess.progress_interval_sec"
        },
        {
            "long": "--log-policy",
            "dest": "log_policy",
            "type": "str",
            "help": "Override Runtime.Subprocess.log_policy: logger | file | quiet | tee-limited"
        }
    ]
}
